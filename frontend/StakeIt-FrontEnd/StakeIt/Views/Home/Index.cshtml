@model List<StakeIt.Models.BetViewModel>

@{
    ViewData["Title"] = "Home";
}

<section class="top-cards">
    <div class="info-card dark-card">
        <p>register to make your own bets</p>
    </div>

    <div class="info-card bright-card">
        <p>referral invite: get 2% of each win of your friend</p>
    </div>
</section>

<section class="bets-section">
    <div class="bets-title">bets</div>

    @if (Model == null || !Model.Any())
    {
        <div class="bet-row">
            <div class="bet-title">No bets available yet</div>
        </div>
    }
    else
    {
        @foreach (var bet in Model)
        {
            <div class="bet-row">
                <div class="bet-title">@bet.Title</div>
                <div class="bet-description">@bet.Description</div>
                <div class="bet-meta">
                    <span>€@bet.Price</span>
                    <span>by @bet.CreatedBy</span>
                </div>
            </div>
        }
    }
</section>